# Single-origin reverse proxy for Komodo.
# APP_ORIGIN=http://localhost   -> serves plain HTTP (the http:// scheme disables auto-TLS)
# APP_ORIGIN=komodo.example.com -> bare host: Caddy auto-provisions HTTPS via Let's Encrypt
{$APP_ORIGIN:http://localhost} {
	# API + health + SSE go to the backend; flush_interval -1 keeps the
	# /api/v1/stream Server-Sent Events unbuffered.
	@api path /api/* /health
	reverse_proxy @api backend:8000 {
		flush_interval -1
	}

	# Everything else is the SvelteKit (adapter-node) frontend.
	reverse_proxy frontend:5173
}
