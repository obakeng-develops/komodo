# ── Mino deployment config ───────────────────────────────────────────────
# Copy to .env and fill in. Generate the secrets + executor keypair with:
#   ./scripts/gen-secrets.sh
# (Never commit .env or the secrets/ directory.)

# Public origin Caddy serves on.
#   http://localhost       -> plain HTTP (the http:// scheme disables auto-TLS), local/dev
#   mino.example.com     -> bare host: Caddy auto-provisions HTTPS via Let's Encrypt
APP_ORIGIN=http://localhost

# Postgres password — any strong value.
POSTGRES_PASSWORD=change-me-postgres

# Shared between backend AND llm-service — MUST be identical on both.
# Encrypts the LLM API key at rest. Keep secret.
ENCRYPTION_KEY=

# Shared between backend AND llm-service — MUST be identical on both.
# Authenticates backend -> llm-service calls. Keep secret.
INTERNAL_API_KEY=

# Signs user session cookies (JWT). Random, secret.
AUTH_SECRET=

# Set to true when serving over HTTPS (domain deploys); keep false on http://localhost.
COOKIE_SECURE=false

# Optional: require this token on the first-run owner setup page so a stranger
# can't claim the owner account on a public URL. Leave blank for open setup
# (fine on localhost / trusted networks).
SETUP_TOKEN=

# Optional headless owner bootstrap. Leave BOTH blank to create the owner via
# the first-run setup page instead.
OWNER_EMAIL=
OWNER_PASSWORD=

# Default LLM provider/model the llm-service talks to (deepseek or openrouter).
# You can also pick these per-account in the UI. The API key itself is added in
# Settings and stored encrypted; it is NOT an env var.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
